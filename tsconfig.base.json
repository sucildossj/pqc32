{
  "compilerOptions": {
    /* ── Language ─────────────────────────────────────────────── */
    "target": "ES2022",
    "lib": ["ES2022"],

    /* ── Modules ──────────────────────────────────────────────── */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* ── Output ───────────────────────────────────────────────── */
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    /* ── Strictness ───────────────────────────────────────────── */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* ── Node ─────────────────────────────────────────────────── */
    /* SHAKE-256 via crypto.createHash("shake256") requires Node ≥ 18 */
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}